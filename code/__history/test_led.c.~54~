#include <18F2685.h>
#device ADC=10
#fuses HS, NOWDT, NOPROTECT, NOLVP, PUT
#use delay(crystal=20000000)

// --- –?nh nghia Pin Map cho TB6612 vŗ H? th?ng ---
#define LED1        PIN_B2   // LED1 (Status) - B?t khi Start, t?t khi END [1, 2]
#define LED2        PIN_B3   // LED2 (Action) - NhŠy khi l?y bi [1, 2]
#define SL          PIN_A2   // IR Sensor TrŠi (Active-LOW) [3, 4]
#define SM          PIN_A3   // IR Sensor Gi?a
#define SR          PIN_A4   // IR Sensor Ph?i
#define BTN         PIN_B7   // Nķt nh?n RUN/STOP (Active-LOW) [5, 6]
#define Trig        PIN_B0   // HC-SR04 Trigger [7, 8]
#define Echo        PIN_B1   // HC-SR04 Echo
#define STBY        PIN_C4   // TB6612 Standby [9, 10]
#define AIN1        PIN_C0   // DIR Motor TrŠi
#define AIN2        PIN_C3   // DIR Motor TrŠi (n?i I/O d? lýi) [Conversation]
#define BIN1        PIN_C5   // DIR Motor Ph?i
#define BIN2        PIN_C6   // DIR Motor Ph?i (n?i I/O d? lýi) [Conversation]


// --- Tham s? h? th?ng ---
#define CHATTER_N   3        // L?c nhi?u 3 m?u liÍn ti?p [11, 12]
#define GRAB_MS     2000     // Th?i gian ch? l?y bi 2s [13, 14]
#define BACK_MS     600      // Th?i gian lýi r?i tr?m [15, 16]
#define STOP_CM     3        // Kho?ng cŠch d?ng t?i tr?m [13, 17]
#define END_CM      5        // Kho?ng cŠch d?ng t?i dŪch [18, 19]

// --- CŠc ki?u d? li?u vŗ Bi?n toŗn c?c ---
typedef enum { 
    STATE_IDLE, STATE_FOLLOW_LINE, STATE_STATION, 
    STATE_STATION_STOP, STATE_STATION_BACK, STATE_NAVIGATION, 
    STATE_ERROR, STATE_END 
} SystemState_t;

volatile uint32_t ms_tick = 0;
volatile uint8_t duty_R_soft = 0; // Software PWM cho motor ph?i [Conversation]
volatile int1 led2_blink_en = 0;  // C? nhŠy LED2 [2, 20]
SystemState_t current_state = STATE_IDLE;
uint8_t checkpoint_id = 1;        // Qu?n lż 3 checkpoint [5, 6]
int1 ball_taken = 0;
uint8_t last_valid_pat = 0x02;

// --- B?ng tra c?u Motor (Lookup Table) --- [21, 22]
typedef struct { uint8_t L; uint8_t R; } MotorCmd_t;
const MotorCmd_t motor_table[23] = {
    {0,   0  }, // 000: M?t line -> dýng last_valid_pat
    {200, 0  }, // 001: L?ch trŠi nhi?u -> r? g?t ph?i
    {160, 160}, // 010: Th?ng lż tu?ng
    {160, 90 }, // 011: L?ch trŠi nh? -> r? ph?i nh?
    {0,   200}, // 100: L?ch ph?i nhi?u -> r? g?t trŠi
    {0,   0  }, // 101: T?m d?ng (Junction)
    {90,  160}, // 110: L?ch ph?i nh? -> r? trŠi nh?
    {0,   0  }  // 111: T?m d?ng (Junction)
};

// --- Tržnh ph?c v? ng?t Timer ---
#int_timer0 // Nh?p tim h? th?ng 1ms [24, 25]
void timer0_isr() {
    ms_tick++;
    set_timer0(63036); // Reset cho 1ms @ 20MHz
    
    // Logic x? lż nhŠy LED2 non-blocking [2, 26]
    if (led2_blink_en) {
        if ((ms_tick % 200) == 0) output_toggle(LED2);
    } else {
        output_low(LED2);
    }
}

#int_timer2 // Software PWM 20kHz cho motor ph?i [25, 27]
void timer2_isr() {
    static uint8_t counter = 0;
    if (++counter >= 250) counter = 0;
    
    if (counter < duty_R_soft) output_high(PIN_C3);
    else output_low(PIN_C3);
}

// --- Hŗm di?u khi?n d?ng co --- [28, 29]
void motor_set(uint8_t l, uint8_t r, uint8_t dir) {
    output_high(STBY);
    if (dir == 1) { // Ti?n
        output_high(AIN1); output_low(AIN2); 
        output_high(BIN1); output_low(BIN2);
    } else if (dir == 2) { // Lýi
        output_low(AIN1); output_high(AIN2); 
        output_low(BIN1); output_high(BIN2);
    } else { // D?ng
        output_low(AIN1); output_low(AIN2); 
        output_low(BIN1); output_low(BIN2);
        l = 0; r = 0;
    }
    set_pwm1_duty((int16)l * 4); // Hardware PWM (BŠnh trŠi - RC2) [30, 31]
    duty_R_soft = r;             // Software PWM (BŠnh ph?i - RC3) [Conversation]
}

// --- Hŗm d?c kho?ng cŠch siÍu ‚m --- [11, 32]
uint8_t get_dist() {
    output_high(Trig); delay_us(10); output_low(Trig);
    uint32_t duration = 0;
    while(!input(Echo) && duration < 2000) duration++;
    set_timer1(0);
    setup_timer_1(T1_INTERNAL | T1_DIV_BY_1);
    while(input(Echo));
    setup_timer_1(T1_DISABLED);
    return (uint8_t)(get_timer1() / 290); // 1cm = 290 ticks @ 5MHz
}

// --- Hŗm d?c pattern c?m bi?n IR ců l?c nhi?u Chatter --- [33, 34]
uint8_t read_pattern() {
    static uint8_t p_prev = 0xFF, p_count = 0, p_conf = 0x02;
    // –?c RA0, RA1, RA2 (Active-LOW: den = 0, tr?ng = 1 -> d?o bit)
    uint8_t raw = (!input(SL) << 2) | (!input(SM) << 1) | !input(SR);
    if (raw == p_prev) {
        if (++p_count >= CHATTER_N) p_conf = raw;
    } else {
        p_prev = raw; p_count = 1;
    }
    return p_conf;
}

// --- Qu?n lż FSM ---
void transition(SystemState_t next) {
    ms_tick = 0;
    current_state = next;
}

void main() {
    // Kh?i t?o GPIO (CCS t? c?u hžnh khi g?i input/output)
    output_low(LED1); output_low(LED2);
    output_low(GRAB_PIN); output_low(RELEASE_PIN);
    
    // Kh?i t?o Timer vŗ PWM [27, 31, 35]
    setup_timer_0(T0_INTERNAL | T0_DIV_4);
    setup_timer_2(T2_DIV_BY_1, 249, 1); // 20kHz base
    setup_ccp1(CCP_PWM);                // Hardware PWM trÍn RC2
    
    enable_interrupts(INT_TIMER0);
    enable_interrupts(INT_TIMER2);
    enable_interrupts(GLOBAL);
    
    while(TRUE) {
        uint8_t pat = read_pattern();
        uint8_t dist = get_dist();
        
        switch(current_state) {
            case STATE_IDLE:
                motor_set(0, 0, 0);
                if (!input(BTN)) {
                    delay_ms(50);
                    uint32_t t_start = ms_tick;
                    while(!input(BTN));
                    if (ms_tick - t_start > 2000) { // Nh?n gi?: Reset CP1 & xůa bi [Conversation]
                        checkpoint_id = 1; ball_taken = 0;
                    }
                    output_high(LED1); // B?t LED tr?ng thŠi khi ch?y [2]
                    transition(STATE_FOLLOW_LINE);
                }
                break;
                
            case STATE_FOLLOW_LINE:
                if (ball_taken == 0 && (pat == 0x05 || pat == 0x07)) transition(STATE_STATION);
                else if (dist <= END_CM) transition(STATE_END);
                else {
                    if (pat == 0) pat = last_valid_pat; // Gi? hu?ng cu?i [36, 37]
                    else last_valid_pat = pat;
                    motor_set(motor_table[pat].L, motor_table[pat].R, 1);
                }
                break;
                
            case STATE_STATION:
                motor_set(80, 80, 1); // BŠm ch?m vŗo tr?m [15, 17]
                if (dist <= STOP_CM) transition(STATE_STATION_STOP);
                break;
                
            case STATE_STATION_STOP:
                motor_set(0, 0, 0);
                output_high(GRAB_PIN);
                led2_blink_en = 1; // NhŠy LED2 khi dang l?y bi [2]
                if (ms_tick > GRAB_MS) {
                    ball_taken = 1; led2_blink_en = 0;
                    output_low(GRAB_PIN); transition(STATE_STATION_BACK);
                }
                break;
                
            case STATE_STATION_BACK:
                motor_set(120, 120, 2); // Lýi kh?i tr?m [28, 38]
                if (ms_tick > BACK_MS) transition(STATE_NAVIGATION);
                break;
                
            case STATE_NAVIGATION:
                motor_set(200, 0, 1); // Quay ph?i t?i ch? [39, 40]
                if (input(SM) && ms_tick > 200) {
                    checkpoint_id = 2; // XŠc nh?n thoŠt tr?m an toŗn [Conversation]
                    transition(STATE_FOLLOW_LINE);
                }
                break;
                
            case STATE_END:
                if (ms_tick < 400) {
                    motor_set(100, 100, 1); // Ti?n thÍm d? ti?p xķc co khŪ [18, 19]
                } else if (ms_tick < 2400) {
                    motor_set(0, 0, 0); output_high(RELEASE_PIN);
                } else {
                    output_low(RELEASE_PIN); output_low(LED1); // T?t LED khi END [2]
                    transition(STATE_IDLE);
                }
                break;
        }
    }
}


