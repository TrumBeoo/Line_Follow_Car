#include <18F2685.h>
#fuses HS, NOWDT, NOPROTECT, NOLVP
#use delay(clock=20000000)

// Motor A
#define MOTOR_PWMA PIN_C2    // CCP1 cho PWM ph?n c?ng
#define MOTOR_AIN1 PIN_C0
#define MOTOR_AIN2 PIN_C3

// Motor B
#define MOTOR_PWMB PIN_C1    // PWM m?m qua Timer2
#define MOTOR_BIN1 PIN_C5
#define MOTOR_BIN2 PIN_C6

// Chung
#define MOTOR_STBY PIN_C4

volatile int8 pwm_duty_b = 0;
volatile int8 pwm_counter = 0;

#INT_TIMER2
void timer2_isr(void) {
    if (pwm_counter < pwm_duty_b) {
        output_high(MOTOR_PWMB);
    } else {
        output_low(MOTOR_PWMB);
    }
    pwm_counter++;
}

void motor_init(void) {
    setup_timer_2(T2_DIV_BY_1, 249, 1);
    setup_ccp1(CCP_PWM);
    set_pwm1_duty(0);
    pwm_duty_b = 0;
    output_low(MOTOR_STBY);
    enable_interrupts(INT_TIMER2);
}

void motor_stop(void) {
    output_low(MOTOR_STBY);
    set_pwm1_duty(0);
    pwm_duty_b = 0;
}

void motor_forward(int8 speed) {
    output_high(MOTOR_STBY);
    // Motor A: ti?n (AIN1=1, AIN2=0)
    output_high(MOTOR_AIN1);
    output_low(MOTOR_AIN2);
    // Motor B: ti?n (BIN1=1, BIN2=0)
    output_high(MOTOR_BIN1);
    output_low(MOTOR_BIN2);
    set_pwm1_duty(speed * 4);
    pwm_duty_b = speed;
}

void motor_backward(int8 speed) {
    output_high(MOTOR_STBY);
    // Motor A: lůi (AIN1=0, AIN2=1)
    output_low(MOTOR_AIN1);
    output_high(MOTOR_AIN2);
    // Motor B: lůi (BIN1=0, BIN2=1)
    output_low(MOTOR_BIN1);
    output_high(MOTOR_BIN2);
    set_pwm1_duty(speed * 4);
    pwm_duty_b = speed;
}

void motor_turn_left(int8 speed) {
    output_high(MOTOR_STBY);
    // Motor A: lůi (AIN1=0, AIN2=1)
    output_low(MOTOR_AIN1);
    output_high(MOTOR_AIN2);
    // Motor B: ti?n (BIN1=1, BIN2=0)
    output_high(MOTOR_BIN1);
    output_low(MOTOR_BIN2);
    set_pwm1_duty(speed * 4);
    pwm_duty_b = speed;
}

void motor_turn_right(int8 speed) {
    output_high(MOTOR_STBY);
    // Motor A: ti?n (AIN1=1, AIN2=0)
    output_high(MOTOR_AIN1);
    output_low(MOTOR_AIN2);
    // Motor B: lůi (BIN1=0, BIN2=1)
    output_low(MOTOR_BIN1);
    output_high(MOTOR_BIN2);
    set_pwm1_duty(speed * 4);
    pwm_duty_b = speed;
}

void main(void) {
    setup_adc(ADC_OFF);
    setup_adc_ports(NO_ANALOGS);
    
    motor_init();
    enable_interrupts(GLOBAL);
    
    while(TRUE) {
        motor_forward(200);
        delay_ms(2000);
        
        motor_backward(200);
        delay_ms(2000);
        
        motor_turn_left(150);
        delay_ms(2000);
        
        motor_turn_right(150);
        delay_ms(2000);
        
        motor_stop();
        delay_ms(2000);
    }
}


