////////////////////////////////////////////////////////////////////////////////
// FILE: motor.h
// DESC: Motor control header - command structure and function declarations
////////////////////////////////////////////////////////////////////////////////

#ifndef MOTOR_H
#define MOTOR_H

// ============================================================================
// MOTOR COMMAND STRUCTURE
// ============================================================================
typedef struct {
    int8 left_pwm;           // Left motor PWM (0-255)
    int8 right_pwm;          // Right motor PWM (0-255)
    int1 direction;          // 1=Forward, 0=Reverse
} MotorCmd_t;

// ============================================================================
// LOOKUP TABLE FOR LINE FOLLOWING
// Located in ROM to save RAM (8 patterns)
// ============================================================================
extern const  MotorCmd_t motor_table[8];  // can save in ROM

// ============================================================================
// FUNCTION PROTOTYPES
// ============================================================================

// Initialize PWM for motor control
void motor_init(void);

// Set motor speeds and direction
void motor_set(int8 left_pwm, int8 right_pwm, int1 direction);

// Get motor command from lookup table based on sensor pattern
MotorCmd_t motor_get_command(int8 pattern);

// Special motor control functions
void motor_stop(void);
void motor_forward(int8 speed);
void motor_reverse(int8 speed);
void motor_turn_right(int8 speed);
void motor_turn_left(int8 speed);
void motor_pivot_right(int8 speed);  // Turn in place
void motor_pivot_left(int8 speed);   // Turn in place

// Enable/disable motor driver
void motor_enable(void);
void motor_disable(void);

#endif // MOTOR_H

