// ============================================================================
// TEST: ULTRASONIC
// ============================================================================
#ifdef TEST_ULTRASONIC
void test_ultrasonic(void) {
    int8 error_count = 0;
    int8 valid_count = 0;
    
    led_indicate_start();
    printf("=== ULTRASONIC TEST START ===\r\n");
    
    while (TRUE) {
        int8 distance_cm = ultrasonic_read_cm();
        int16 distance_mm = ultrasonic_read_mm();
        
        if (distance_cm == ULTRA_ERROR) {
            error_count++;
            printf("Error: No echo (count: %u)\r\n", error_count);
            led_indicate_fail();
            
            if (error_count > 10) {
                printf("Too many errors - check connections\r\n");
                led_indicate_error();
                delay_ms(2000);
                error_count = 0;
            }
        } else {
            valid_count++;
            printf("Distance: %u cm (%lu mm) [Valid: %u]\r\n", 
                   distance_cm, distance_mm, valid_count);
            
            // Test distance thresholds
            if (distance_cm <= STOP_CM_STATION) {
                printf("  -> STATION RANGE\r\n");
                sensors_led_status(TRUE);
                sensors_led_action(TRUE);
            } else if (distance_cm <= STOP_CM_END) {
                printf("  -> END RANGE\r\n");
                sensors_led_status(TRUE);
                led_indicate_activity();
            } else {
                printf("  -> CLEAR\r\n");
                led_indicate_success();
            }
            
            error_count = 0;  // Reset error count on valid reading
        }
        
        // Test summary every 20 readings
        if ((valid_count + error_count) % 20 == 0) {
            printf("Summary: %u valid, %u errors\r\n", valid_count, error_count);
            if (error_count < 3) {
                led_indicate_success();
            } else {
                led_indicate_error();
            }
        }
        
        delay_ms(500);
    }
}
#endif

