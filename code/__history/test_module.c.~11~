// ============================================================================
// TEST: CHECKPOINT
// ============================================================================
#ifdef TEST_CHECKPOINT
void test_checkpoint(void) {
    led_indicate_start();
    printf("=== CHECKPOINT TEST START ===\r\n");
    
    // Test checkpoint save/restore
    Checkpoint_t test_checkpoints[] = {CP_START, CP_AFTER_NAVIGATION, CP_BEFORE_END};
    
    for (int8 i = 0; i < 3; i++) {
        printf("Testing checkpoint %u:\r\n", test_checkpoints[i]);
        
        // Save checkpoint
        ball_grabbed = (i > 0);  // Have ball after first checkpoint
        fsm_save_checkpoint(test_checkpoints[i]);
        printf("  Saved: CP=%u, Ball=%u\r\n", current_checkpoint, ball_grabbed);
        led_indicate_activity();
        delay_ms(500);
        
        // Simulate system reset
        current_checkpoint = CP_START;
        ball_grabbed = FALSE;
        
        // Restore checkpoint
        fsm_restore_checkpoint();
        delay_ms(100);  // Allow state transition
        
        printf("  Restored: CP=%u, Ball=%u\r\n", current_checkpoint, ball_grabbed);
        
        if (current_checkpoint == test_checkpoints[i]) {
            printf("  CHECKPOINT PASS\r\n");
            led_indicate_success();
        } else {
            printf("  CHECKPOINT FAIL\r\n");
            led_indicate_fail();
        }
        
        delay_ms(1000);
    }
    
    printf("=== CHECKPOINT TEST COMPLETE ===\r\n");
    led_indicate_success();
    
    while (TRUE) {
        delay_ms(1000);
    }
}
