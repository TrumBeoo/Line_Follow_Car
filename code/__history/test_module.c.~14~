// ============================================================================
// LED STATUS INDICATORS
// ============================================================================
void led_indicate_start(void) {
    sensors_led_status(TRUE);   // LED1 ON - test starting
    sensors_led_action(FALSE);  // LED2 OFF - reset
    delay_ms(500);
}

void led_indicate_success(void) {
    sensors_led_status(TRUE);   // LED1 ON - system OK
    sensors_led_action(TRUE);   // LED2 ON - test passed
}

void led_indicate_fail(void) {
    sensors_led_status(FALSE);  // LED1 OFF - system error
    sensors_led_action(FALSE);  // LED2 OFF - test failed
}

void led_indicate_activity(void) {
    static int1 blink_state = FALSE;
    blink_state = !blink_state;
    sensors_led_action(blink_state);  // LED2 blink - activity
}

void led_indicate_error(void) {
    // Both LEDs blink alternately for error
    for (int i = 0; i < 6; i++) {
        sensors_led_status(i % 2);
        sensors_led_action(!(i % 2));
        delay_ms(200);
    }
}

// ============================================================================
// TEST: SENSORS
// ============================================================================
#ifdef TEST_SENSORS
void test_sensors(void) {
    int8 test_count = 0;
    int8 valid_readings = 0;
    
    led_indicate_start();
    
    while (TRUE) {
        int8 raw = sensors_read_raw();
        int8 filtered = sensors_read_filtered();
        int8 last_valid = sensors_get_last_valid();
        
        // LED1: Line detection - ON when any sensor sees black line
        if (filtered != 0b000) {  // Any sensor detects line
            sensors_led_status(TRUE);   // LED1 ON - line detected
        } else {
            sensors_led_status(FALSE);  // LED1 OFF - all white surface
        }
        
        // Test logic validation with LED2
        if (sensors_is_valid_line(filtered)) {
            valid_readings++;
            sensors_led_action(TRUE);   // LED2 ON - valid line pattern
        } else if (sensors_is_lost(filtered)) {
            sensors_led_action(FALSE);  // LED2 OFF - line lost
        } else if (sensors_is_intersection(filtered)) {
            // Both LEDs ON for intersection
            sensors_led_status(TRUE);
            sensors_led_action(TRUE);
        } else if (sensors_is_tjunction(filtered)) {
            // LED1 ON (line detected), LED2 blink (special case)
            sensors_led_status(TRUE);
            led_indicate_activity();
        }
        
        test_count++;
        if (test_count >= 100) {
            if (valid_readings > 80) {
                led_indicate_success();
            } else {
                led_indicate_error();
            }
            test_count = 0;
            valid_readings = 0;
            delay_ms(2000);  // Pause between test cycles
        }
        
        delay_ms(100);
    }
}
#endif

