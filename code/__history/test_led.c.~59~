#include <18F2685.h>
#fuses HS, NOWDT, NOPROTECT, NOLVP, PUT
#use delay(crystal=20000000)

// --- �?nh nghia Pin Map ---
#define LED1        PIN_B2   // LED Status - B?t khi ch?y, t?t khi END
#define LED2        PIN_B3   // LED Action - Nh�y khi dang l?y bi
#define SL          PIN_A2   // IR Tr�i (Active-LOW) [1]
#define SM          PIN_A3   // IR Gi?a
#define SR          PIN_A4   // IR Ph?i
#define BTN         PIN_B7   // N�t nh?n RUN/STOP (Active-LOW) [2, 3]
#define Trig        PIN_A0   // Si�u �m Trigger
#define Echo        PIN_A1   // Si�u �m Echo
#define STBY        PIN_C4   // TB6612 Standby [4, 5]
#define AIN1        PIN_C0   // Motor Tr�i DIR 1
#define AIN2        PIN_C3   // Motor Tr�i DIR 2 (L�i)
#define BIN1        PIN_C5   // Motor Ph?i DIR 1 (�� d?i t? B2)
#define BIN2        PIN_C6   // Motor Ph?i DIR 2 (�� d?i t? B3)
#define PWMA_PIN    PIN_C2   // Software PWM Motor Tr�i
#define PWMB_PIN    PIN_C1   // Software PWM Motor Ph?i
#define GRAB_PIN    PIN_C4   // Co c?u l?y bi
#define RELEASE_PIN PIN_C5   // Co c?u th? bi

// --- Tham s? h? th?ng ---
#define CHATTER_N   3        // L?c nhi?u Chatter [6, 7]
#define GRAB_MS     2000     // Th?i gian ch? l?y bi [6]
#define BACK_MS     600      // Th?i gian l�i r?i tr?m [8]
#define STOP_CM     3        // Kho?ng c�ch d?ng t?i tr?m [9]
#define END_CM      5        // Kho?ng c�ch nh?n di?n d�ch [9]

// --- Ki?u d? li?u v� Bi?n to�n c?c ---
typedef enum { 
    STATE_IDLE, STATE_FOLLOW_LINE, STATE_STATION, 
    STATE_STATION_STOP, STATE_STATION_BACK, STATE_NAVIGATION, 
    STATE_END 
} SystemState_t;

volatile int32_t ms_tick = 0;
volatile int8_t duty_L = 0;   // Software PWM Tr�i
volatile int8_t duty_R = 0;   // Software PWM Ph?i
volatile int1 led2_blink_en = 0;
SystemState_t current_state = STATE_IDLE;
int8_t checkpoint_id = 1;     // CP1=Start, CP2=Sau Tr?m [6, 10]
int1 ball_taken = 0;
int8_t last_valid_pat = 0x02; // Pattern di th?ng m?c d?nh [11]

// --- B?ng tra c?u Motor (Lookup Table) [11, 12] ---
typedef struct { int8_t L; int8_t R; } MotorCmd_t;
const MotorCmd_t motor_table[13] = {
    {0,   0  }, // 000: M?t line
    {200, 0  }, // 001: L?ch tr�i nhi?u -> r? g?t ph?i
    {160, 160}, // 010: Th?ng l� tu?ng
    {160, 90 }, // 011: L?ch tr�i nh? -> r? ph?i nh?
    {0,   200}, // 100: L?ch ph?i nhi?u -> r? g?t tr�i
    {0,   0  }, // 101: Junction T
    {90,  160}, // 110: L?ch ph?i nh? -> r? tr�i nh?
    {0,   0  }  // 111: Ng� tu
};

// --- Tr�nh ph?c v? ng?t ---
#int_timer0 // Nh?p tim h? th?ng 1ms
void timer0_isr() {
    ms_tick++;
    set_timer0(63036); // Reset 1ms @ 20MHz
    if (led2_blink_en && (ms_tick % 200 == 0)) output_toggle(LED2);
    else if (!led2_blink_en) output_low(LED2);
}

#int_timer2 // Software PWM cho C? 2 motor @ 20kHz [14-16]
void timer2_isr() {
    static int8_t counter = 0;
    if (++counter >= 250) counter = 0; // PR2 tuong duong 250 ticks
    
    // �i?u khi?n d?ng co tr�i (RC2)
    if (counter < duty_L) output_high(PWMA_PIN);
    else output_low(PWMA_PIN);
    
    // �i?u khi?n d?ng co ph?i (RC3)
    if (counter < duty_R) output_high(PWMB_PIN);
    else output_low(PWMB_PIN);
}

// --- C�c h�m ch?c nang ---
void motor_set(uint8_t l, uint8_t r, uint8_t dir) {
    output_high(STBY);
    if (dir == 1) {      // Ti?n
        output_high(AIN1); output_low(AIN2); 
        output_high(BIN1); output_low(BIN2);
    } else if (dir == 2) { // L�i
        output_low(AIN1); output_high(AIN2); 
        output_low(BIN1); output_high(BIN2);
    } else {             // D?ng
        output_low(AIN1); output_low(AIN2); 
        output_low(BIN1); output_low(BIN2);
        l = 0; r = 0;
    }
    duty_L = l; duty_R = r; // C?p nh?t cho Software PWM
}

uint8_t get_dist() {
    output_high(Trig); delay_us(10); output_low(Trig);
    uint32_t duration = 0;
    while(!input(Echo) && duration < 2000) duration++;
    set_timer1(0);
    setup_timer_1(T1_INTERNAL | T1_DIV_BY_1);
    while(input(Echo));
    setup_timer_1(T1_DISABLED);
    return (uint8_t)(get_timer1() / 290); // 1cm = 290 ticks [17]
}

uint8_t read_pattern() {
    static uint8_t p_prev = 0xFF, p_count = 0, p_conf = 0x02;
    uint8_t raw = (!input(SL) << 2) | (!input(SM) << 1) | !input(SR);
    if (raw == p_prev) {
        if (++p_count >= CHATTER_N) p_conf = raw;
    } else {
        p_prev = raw; p_count = 1;
    }
    return p_conf;
}

void transition(SystemState_t next) {
    ms_tick = 0;
    current_state = next;
}

void main() {
    setup_adc_ports(NO_ANALOGS); // ADCON1 = 0x0F [11, 18]
    output_low(LED1); output_low(LED2);
    output_low(GRAB_PIN); output_low(RELEASE_PIN);
    
    setup_timer_0(T0_INTERNAL | T0_DIV_4);
    setup_timer_2(T2_DIV_BY_1, 249, 1); // 20kHz base [16]
    setup_ccp1(CCP_OFF);                // T?t Hardware PWM d? d�ng Software PWM
    
    enable_interrupts(INT_TIMER0);
    enable_interrupts(INT_TIMER2);
    enable_interrupts(GLOBAL);
    
    while(TRUE) {
        uint8_t pat = read_pattern();
        uint8_t dist = (current_state == STATE_STATION || current_state == STATE_FOLLOW_LINE) ? get_dist() : 255;

        switch(current_state) {
            case STATE_IDLE:
                motor_set(0, 0, 0);
                if (!input(BTN)) {
                    delay_ms(50);
                    uint32_t t_start = ms_tick;
                    while(!input(BTN));
                    if (ms_tick - t_start > 2000) { // Nh?n gi?: Reset CP1 & x�a bi [History]
                        checkpoint_id = 1; ball_taken = 0;
                    }
                    output_high(LED1); transition(STATE_FOLLOW_LINE);
                }
                break;

            case STATE_FOLLOW_LINE:
                if (ball_taken == 0 && (pat == 0x05 || pat == 0x07)) transition(STATE_STATION);
                else if (dist <= END_CM) transition(STATE_END);
                else {
                    if (pat == 0) pat = last_valid_pat; // M?t line: gi? hu?ng cu?i [19, 20]
                    else last_valid_pat = pat;
                    motor_set(motor_table[pat].L, motor_table[pat].R, 1);
                }
                break;

            case STATE_STATION:
                motor_set(80, 80, 1); // B�m ch?m v�o tr?m [8, 21]
                if (dist <= STOP_CM) transition(STATE_STATION_STOP);
                break;

            case STATE_STATION_STOP:
                motor_set(0, 0, 0);
                output_high(GRAB_PIN); led2_blink_en = 1;
                if (ms_tick > GRAB_MS) { // Ch? 2s co c?u co kh� [6, 22]
                    ball_taken = 1; led2_blink_en = 0;
                    output_low(GRAB_PIN); transition(STATE_STATION_BACK);
                }
                break;

            case STATE_STATION_BACK:
                motor_set(120, 120, 2); // L�i kh?i tr?m [23, 24]
                if (ms_tick > BACK_MS) transition(STATE_NAVIGATION);
                break;

            case STATE_NAVIGATION:
                motor_set(200, 0, 1); // R? ph?i quay l?i line ch�nh [25, 26]
                if (input(SM) && ms_tick > 200) {
                    checkpoint_id = 2; transition(STATE_FOLLOW_LINE);
                }
                break;

            case STATE_END:
                if (ms_tick < 400) motor_set(100, 100, 1); // Ti?n th�m d? ti?p x�c co kh� [27, 28]
                else if (ms_tick < 2400) {
                    motor_set(0, 0, 0); output_high(RELEASE_PIN);
                } else {
                    output_low(RELEASE_PIN); output_low(LED1);
                    transition(STATE_IDLE);
                }
                break;
        }
    }
}
