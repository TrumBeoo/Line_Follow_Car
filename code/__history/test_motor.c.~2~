#include <18F2685.h>
#fuses HS, NOWDT, NOPROTECT, NOLVP
#use delay(clock=20000000)

#define MOTOR_PWMA PIN_C2
#define MOTOR_PWMB PIN_C1
#define MOTOR_AIN1 PIN_C5
#define MOTOR_BIN1 PIN_C4
#define MOTOR_STBY PIN_C3

#define BUTTON_POWER PIN_B7
#define BUTTON1 PIN_B0
#define BUTTON2 PIN_B1

int1 system_on = FALSE;
int8 motor_state = 0; // 0=stop, 1=forward, 2=backward, 3=left, 4=right

void motor_init(void) {
    setup_timer_2(T2_DIV_BY_1, 249, 1);
    setup_ccp1(CCP_PWM);
    setup_ccp2(CCP_PWM);
    set_pwm1_duty(0);
    set_pwm2_duty(0);
    output_low(MOTOR_STBY);
}

void motor_stop(void) {
    output_low(MOTOR_STBY);
    set_pwm1_duty(0);
    set_pwm2_duty(0);
}

void motor_forward(int8 speed) {
    output_high(MOTOR_STBY);
    output_high(MOTOR_AIN1);
    output_high(MOTOR_BIN1);
    set_pwm1_duty(speed * 4);
    set_pwm2_duty(speed * 4);
}

void motor_backward(int8 speed) {
    output_high(MOTOR_STBY);
    output_low(MOTOR_AIN1);
    output_low(MOTOR_BIN1);
    set_pwm1_duty(speed * 4);
    set_pwm2_duty(speed * 4);
}

void motor_turn_left(int8 speed) {
    output_high(MOTOR_STBY);
    output_low(MOTOR_AIN1);
    output_high(MOTOR_BIN1);
    set_pwm1_duty(speed * 4);
    set_pwm2_duty(speed * 4);
}

void motor_turn_right(int8 speed) {
    output_high(MOTOR_STBY);
    output_high(MOTOR_AIN1);
    output_low(MOTOR_BIN1);
    set_pwm1_duty(speed * 4);
    set_pwm2_duty(speed * 4);
}

#INT_RB
void portb_isr(void) {
    int8 portb = input_b();
    delay_ms(50);
    
    if (!input(BUTTON_POWER)) {
        system_on = !system_on;
        if (!system_on) {
            motor_stop();
            motor_state = 0;
        }
    }
    
    if (system_on) {
        if (!input(BUTTON1)) {
            motor_state++;
            if (motor_state > 4) motor_state = 0;
        }
        
        if (!input(BUTTON2)) {
            motor_stop();
            motor_state = 0;
        }
    }
}

void main(void) {
    setup_adc(ADC_OFF);
    setup_adc_ports(NO_ANALOGS);
    
    set_tris_b(0b10000011);
    set_tris_c(0b00000000);
    port_b_pullups(0b10000011);
    
    motor_init();
    
    enable_interrupts(INT_RB);
    enable_interrupts(GLOBAL);
    
    while(TRUE) {
        if (system_on) {
            switch(motor_state) {
                case 0: motor_stop(); break;
                case 1: motor_forward(200); break;
                case 2: motor_backward(200); break;
                case 3: motor_turn_left(150); break;
                case 4: motor_turn_right(150); break;
            }
        }
        delay_ms(100);
    }
}

